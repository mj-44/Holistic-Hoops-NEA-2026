CLASS HomePage INHERITS FROM Frame
    
    FUNCTION __init__(parent, controller)
        CALL parent constructor WITH parent, background_color = "#000000"
        SET this.controller TO controller

        SET main_frame TO create_frame(this)
        PLACE main_frame AT relative_x = 0.5, relative_y = 0.5, anchor = "center"

        SET title TO NEW StyledLabel(
            main_frame,
            text = "Hollistic Hoops",
            size = 28,
            bold = TRUE
        )
        PACK title WITH vertical_padding = (0, 50)

        SET subtitle TO NEW StyledLabel(
            main_frame,
            text = "Train, Compete, Repeat",
            size = 14
        )
        PACK subtitle WITH vertical_padding = (0, 80)

        SET loginButton TO NEW ButtonStyle(
            main_frame,
            text = "Login",
            command = LAMBDA FUNCTION: controller.show_page("LoginPage"),
            width = 20
        )
        PACK loginButton WITH vertical_padding = 15

        SET registerButton TO NEW ButtonStyle(
            main_frame,
            text = "Register",
            command = LAMBDA FUNCTION: controller.show_page("RegisterPage"),
            width = 20
        )
        PACK registerButton WITH vertical_padding = 15
    END FUNCTION
    
END CLASS